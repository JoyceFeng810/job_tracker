# Optional — ONLY for a maintainer who wants to ship the app with a built-in
# Google OAuth client so end-users skip the Cloud Console setup.
#
# Leave BLANK for the public/open-source build: the app then asks each user to
# create their own OAuth client (see README → "2. Connect Gmail").
#
# These are read from the real environment (process.env) at launch/build time —
# the app does NOT auto-load this file. To use them, export the variables before
# running, e.g.:
#   JT_GOOGLE_CLIENT_ID=xxx JT_GOOGLE_CLIENT_SECRET=yyy npm run build:mac
#
# Never commit a filled-in copy. .env is gitignored.

JT_GOOGLE_CLIENT_ID=
JT_GOOGLE_CLIENT_SECRET=
